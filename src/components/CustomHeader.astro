---
import Default from '@astrojs/starlight/components/Header.astro';
import { Icon } from '@astrojs/starlight/components';
---

<!-- 保留完整的默认头部（包含搜索框和主题切换） -->
<Default />

<!-- 自定义投诉按钮，放在右侧 -->
<div class="custom-complaint-wrapper">
  <a 
    href="/report/"
    class="custom-complaint"
    aria-label="投诉"
    title="投诉与举报"
  >
    <Icon name="warning" />
    <span class="complaint-text">投诉</span>
  </a>
</div>

<style is:global>
  /* 自定义投诉按钮样式 */
  .custom-complaint-wrapper {
    display: flex;
    align-items: center;
    margin-left: 0.5rem;
    order: 100; /* 确保它在右侧 */
  }
  
  .custom-complaint {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem;
    color: var(--sl-color-text);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }
  
  .custom-complaint:hover {
    color: var(--sl-color-text-accent);
  }
  
  .custom-complaint svg {
    width: 1.2rem;
    height: 1.2rem;
    fill: currentColor;
  }
  
  /* 移动端适配 - 所有元素都在一行，不折叠 */
  @media (max-width: 50rem) {
    /* 头部容器：允许换行但不折叠图标 */
    .site-header {
      flex-wrap: wrap !important;
      padding: 0.5rem !important;
      height: auto !important;
      min-height: 4rem;
    }
    
    /* 标题区域：适当缩小 */
    .site-header .title-wrapper {
      font-size: 0.9rem !important;
      white-space: nowrap;
    }
    
    /* 社交图标区域：保持显示 */
    .site-header .social-icons {
      display: flex !important;
      margin-left: 0.5rem !important;
    }
    
    /* 主题切换按钮：保持显示 */
    .site-header .theme-toggle {
      display: flex !important;
      margin-left: 0.5rem !important;
    }
    
    /* 投诉按钮容器：调整位置 */
    .custom-complaint-wrapper {
      margin-left: auto;
      order: 2;
    }
    
    /* 投诉按钮：移动端只显示图标 */
    .custom-complaint .complaint-text {
      display: none;
    }
    
    .custom-complaint svg {
      width: 1.5rem;
      height: 1.5rem;
    }
    
    /* 搜索框：单独放一行 */
    .site-header .search {
      order: 999 !important;
      width: 100% !important;
      margin-top: 0.5rem !important;
      margin-left: 0 !important;
      flex: 0 0 100% !important;
    }
    
    /* 隐藏移动端折叠按钮（如果有） */
    .site-header .mobile-nav-toggle {
      display: none !important;
    }
  }
</style>
