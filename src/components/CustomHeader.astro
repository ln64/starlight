---
import Default from '@astrojs/starlight/components/Header.astro';
import { Icon } from '@astrojs/starlight/components';
---

<!-- 保留原有头部结构 -->
<Default />

<!-- 自定义投诉按钮（放在右上角） -->
<div class="custom-complaint-wrapper">
  <a 
    href="/report/"  // 改成相对路径，确保跳转到你的投诉页面
    class="custom-complaint"
    aria-label="投诉"
    title="投诉与举报"
  >
    <Icon name="warning" />
    <span class="complaint-text">投诉</span>
  </a>
</div>

<style is:global>
  /* 隐藏默认的移动端折叠按钮 */
  .site-header .mobile-nav-toggle {
    display: none !important;
  }
  
  /* 隐藏默认的社交图标区域 */
  .site-header .social-icons {
    display: none !important;
  }
  
  /* 自定义投诉按钮容器 */
  .custom-complaint-wrapper {
    display: flex;
    align-items: center;
    margin-left: 0.5rem;
  }
  
  .custom-complaint {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem;
    color: var(--sl-color-text);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }
  
  .custom-complaint:hover {
    color: var(--sl-color-text-accent);
  }
  
  .custom-complaint svg {
    width: 1.2rem;
    height: 1.2rem;
    fill: currentColor;
  }
  
  /* 移动端适配 */
  @media (max-width: 50rem) {
    .site-header {
      flex-wrap: wrap !important;
      padding: 0.5rem !important;
      height: auto !important;
    }
    
    .custom-complaint-wrapper {
      margin-left: auto;
    }
    
    .custom-complaint {
      padding: 0.3rem !important;
    }
    
    .custom-complaint .complaint-text {
      display: none; /* 移动端只显示图标 */
    }
    
    .custom-complaint svg {
      width: 1.5rem;
      height: 1.5rem;
    }
    
    .site-header .search {
      order: 999 !important;
      width: 100% !important;
      margin-top: 0.5rem !important;
      margin-left: 0 !important;
    }
  }
</style>
